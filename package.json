{
  "name": "ghost",
  "version": "0.1.0",
  "description": "AI desktop assistant — overlays a ghost cursor to guide users through any UI",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n renderer,electron -c cyan,yellow \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite overlay-renderer --port 5173",
    "dev:electron": "wait-on http://localhost:5173 && npm run build:electron && electron .",
    "build:electron": "esbuild electron/main.ts electron/preload.ts --bundle --platform=node --external:electron --outdir=dist/electron --format=cjs --sourcemap",
    "build:renderer": "vite build overlay-renderer",
    "build": "npm run build:electron && npm run build:renderer",
    "typecheck": "tsc --noEmit -p electron/tsconfig.json && tsc --noEmit -p overlay-renderer/tsconfig.json",
    "package:win": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.ghost.assistant",
    "productName": "Ghost",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "package.json"
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    }
  },
  "dependencies": {
    "framer-motion": "^11.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "esbuild": "^0.24.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "wait-on": "^8.0.0"
  }
}
